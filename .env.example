# ============================================================
# Req-Tracker AI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Data Source ---
# "dummy" uses local JSON file (default for POC demo)
# "jira" uses real JIRA API
DATASOURCE_MODE=dummy

# --- Graph Backend ---
# "networkx" uses in-memory graph (default, zero-infra)
# "neo4j" uses Neo4j database
GRAPH_BACKEND=networkx

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...

# --- JIRA (only needed when DATASOURCE_MODE=jira) ---
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=CAM

# --- Neo4j (only needed when GRAPH_BACKEND=neo4j) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# --- Agent Config ---
BATCH_SIZE=5
APPROVAL_THRESHOLD=0.75
DUMMY_LATENCY_MS=0
