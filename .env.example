# ============================================================
# Req-Tracker AI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Data Source (레거시 dummy 모드) ---
# "dummy" uses local JSON file (default for POC demo)
DATASOURCE_MODE=dummy

# --- Ingest Source (Phase 2 실데이터 수집) ---
# "auto" : data/jira_fetch/*.json 있으면 file, JIRA_TOKEN 있으면 jira (기본값)
# "file" : Claude MCP로 저장한 data/jira_fetch/*.json 읽기 (자격증명 불필요)
# "jira" : JIRA REST API 직접 연결 (아래 JIRA 설정 필요)
INGEST_SOURCE=auto

# --- Graph Backend ---
# "networkx" uses in-memory graph (default, zero-infra)
# "neo4j" uses Neo4j database
GRAPH_BACKEND=networkx

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...

# --- JIRA (only needed when DATASOURCE_MODE=jira) ---
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=CAM

# --- Neo4j (only needed when GRAPH_BACKEND=neo4j) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# --- LLM Model ---
# 사내 폐쇄망 Claude Code는 모델명이 다를 수 있음. 환경에 맞게 변경.
# 예: claude-sonnet-4-5, claude-3-5-sonnet-20241022, 사내 모델 ID
LLM_MODEL=claude-sonnet-4-6

# --- Agent Config ---
BATCH_SIZE=5
APPROVAL_THRESHOLD=0.75
DUMMY_LATENCY_MS=0
